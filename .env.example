# Copy to .env (loaded only by docker-compose, not by the app directly).
PIXEL_AGENTS_TOKEN=change-me
PIXEL_AGENTS_HOST=0.0.0.0
PIXEL_AGENTS_PORT=8765
PIXEL_AGENTS_REPLAY_DIR=/data/replay
# Host path to the Copilot Chat debug-logs root for the active VS Code workspace.
# Override per machine; the default in docker-compose.yml points at this dev box.
# one example
COPILOT_DEBUG_LOG_DIR=/path/to/copilot-debug-logs
# When true, replay all existing JSONL records on startup (otherwise only tail new ones).
PIXEL_AGENTS_ADAPTERS_REPLAY_FROM_START=false
